{
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": "@next_public_api_url",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@next_public_stripe_publishable_key"
  },
  "redirects": [
    {
      "source": "/www.(.*)",
      "destination": "https://elitcoach.co/$1",
      "permanent": true
    }
  ]
}
