generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  name     String?
  role     String?

  goals    Goal[]
  clients  Client[]
}

model Goal {
  id          Int      @id @default(autoincrement())
  title       String
  description String?

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  coachId     Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id       Int    @id @default(autoincrement())
  name     String

  userId   Int
  user     User   @relation(fields: [userId], references: [id])

  coachId  Int?

  goals    Goal[]
}

model UserRole {
  id     Int    @id @default(autoincrement())
  userId Int
  role   String
}
