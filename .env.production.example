# ElitCoach — Production Environment Variables
# ⚠ Ne jamais committer ce fichier avec de vraies valeurs

# Base de données (Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"

# JWT — Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERATE_A_STRONG_64_CHAR_SECRET_HERE"
JWT_REFRESH_SECRET="GENERATE_A_DIFFERENT_64_CHAR_SECRET"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Stripe Live
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Brevo (emails)
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM="hello@elitcoach.co"

# Cloudinary (vidéos)
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# Supabase (storage)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."

# Redis (Upstash)
REDIS_URL="rediss://:[PASSWORD]@[HOST].upstash.io:6380"

# App
FRONTEND_URL="https://elitcoach.co"
PORT=3001
NODE_ENV=production
